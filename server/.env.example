# Database connection URL (for local dev, default PostgreSQL username is postgres)
DATABASE_URL=postgresql+asyncpg://postgres:postgres123@localhost:5432/docmind

# JWT Authentication Config
JWT_SECRET_KEY=secure-token-development-only-secret-987654321
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Storage Config
UPLOAD_DIR=uploads

# AI Provider API Keys (Fill in either of these if using LLM features)
GEMINI_API_KEY=
OPENAI_API_KEY=
